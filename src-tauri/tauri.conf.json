{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "judgement-brain",
  "version": "0.1.2",
  "identifier": "com.jphack.judgement-brain",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "judgement-brain",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$APPDATA/**"]
      },
      "csp": "default-src 'self' asset: http://asset.localhost; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; frame-src asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "deb",
      "appimage",
      "app",
      "dmg"
    ],
    "resources": [
      "models/gemma-3-1b-it-q4_0.gguf",
      "models/gemma-270m-gguf/gemma-3-270m-it-Q4_K_M.gguf",
      "models/gemma-270m-gguf/gemma-3-270m-it-Q6_K.gguf",
      "models/gemma-270m-gguf/gemma-3-270m-it-Q8_0.gguf",
      "models/gemma-270m-gguf/gemma-3-270m-it-F16.gguf"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
