{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "dialog:allow-open",
    "core:menu:allow-new",
    "core:menu:allow-set-as-app-menu",
    "core:menu:allow-append",
    "core:menu:allow-popup"
  ]
}
